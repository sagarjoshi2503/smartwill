# Same Google OAuth Client ID as web/.env.example — used server-side to verify
# the ID token's signature. Not a secret, but must match the frontend's value.
VITE_GOOGLE_CLIENT_ID=

# MongoDB connection string. Server-side only, never exposed to the frontend.
MONGODB_URI=

# Database name within the MongoDB cluster above. Defaults to "smartwill" if
# unset, so production (Vercel) doesn't need to set this. Local dev should
# point at a separate database (e.g. "smartwill-dev") to avoid touching prod data.
DB_NAME=

# Recipient notified by email whenever a testator submits their Will for review.
ADMIN_REVIEW_EMAIL=

# Email is sent via either Resend or SendGrid, chosen by the Vercel flags
# "use-resend-for-email" / "use-sendgrid-for-email" (see _app/shared/email.py).
# Only the provider selected by whichever flag is enabled needs to be
# configured; if the selected provider's keys are empty, the notification is
# skipped (and logged) rather than failing the Will action that triggered it.

# Resend (https://resend.com) transactional email API.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SendGrid (https://sendgrid.com) transactional email API.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Vercel Flags SDK — used by api/flags.ts to evaluate the "enable-admin-button" flag.
FLAGS_SECRET=
FLAGS=

# Twilio (https://twilio.com) — used to deliver OTP codes by SMS during phone
# sign-in. account_sid and auth_token are secrets; from_number is the
# project's provisioned Twilio number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

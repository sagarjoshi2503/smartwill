# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials).
# Not a secret — it's fine that this ends up in the client bundle (VITE_ prefix required
# for that). The API project also needs the same value (see api/.env.example) to verify
# the ID token's signature server-side.
VITE_GOOGLE_CLIENT_ID=

# Base URL of the deployment that runs the FastAPI backend (Vercel — GitHub
# Pages is static-only and can't run serverless functions at all). The frontend
# always calls `${VITE_API_BASE_URL}/api/...`, so every build — whether it
# ends up on Vercel or GitHub Pages — talks to the one real backend on Vercel.
# Leave empty (or set to the exact same origin) when the frontend IS the Vercel
# deployment; only needs a value for builds served from somewhere else.
VITE_API_BASE_URL=https://smartwill-seven.vercel.app

# Razorpay hosted Payment Link. The testator is redirected here after
# successfully submitting a Will for admin review/approval. If unset, the
# redirect is skipped.
VITE_RAZORPAY_PAYMENT_LINK=https://rzp.io/rzp/NRa4G1wv
